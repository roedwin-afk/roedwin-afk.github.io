---
import '../styles/global.css';
export interface Props {
  title?: string;
}
const { title = 'Edwin Villalobos — Web Dev & Automation Specialist' } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Portafolio de Edwin Villalobos — Desarrollador Web y Especialista en Automatización basado en El Salvador." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  </head>
  <body>
    <slot />
  </body>
</html>
