---
const projects = [
  {
    type: 'Red SEO · PROMAICA',
    title: '14 Landing Pages Astro',
    desc: 'Red de sitios estáticos multiidioma (EN/ES) para posicionamiento SEO internacional de productos industriales. Cada sitio incluye i18n, blog headless con WordPress, mapas Leaflet y formularios Zoho.',
    tags: ['Astro', 'i18n', 'WordPress Headless', 'GitHub Actions'],
    url: '',
  },
  {
    type: 'Automatización · PROMAICA',
    title: 'Power Platform Workflows',
    desc: 'Flujos de Power Automate para procesamiento de correos, extracción de datos JSON y traducciones condicionales. Power Apps con modelo de acceso basado en roles para confirmaciones de pago.',
    tags: ['Power Automate', 'Power Apps', 'PAD', 'Excel VBA'],
    url: '',
  },
  {
    type: 'Calculadora · mequipo.com',
    title: 'Panel Insulation Calculator',
    desc: 'Landing bilingüe con calculadora interactiva de aislamiento térmico. Paleta negra/amarilla con tipografía Barlow Condensed, carousel hero y sección de métricas animadas.',
    tags: ['Astro', 'TypeScript', 'i18n', 'CSS'],
    url: 'https://landing.mequipo.com',
  },
  {
    type: 'Freelance · Fiverr',
    title: 'Consultoría Power Automate',
    desc: 'Tutorías y proyectos de automatización para clientes internacionales. Diseño de flujos, solución de problemas y entrega de automatizaciones listas para producción con N8N y Power Automate Cloud.',
    tags: ['Power Automate', 'N8N', 'RPA'],
    url: '',
  },
  {
    type: 'RPA · Especialización',
    title: 'UiPath REFramework',
    desc: 'Implementaciones con el Robotic Enterprise Framework: gestión de Queues, ciclos de vida de transacciones, Orchestrator y documentación PDD/SDD para automatizaciones empresariales.',
    tags: ['UiPath', 'REFramework', 'Orchestrator', 'ElectroNeek'],
    url: '',
  },
  {
    type: 'Marketing · Cliente',
    title: 'Heidi Organic Beauty',
    desc: 'Estrategia Meta Ads Click-to-WhatsApp con embudo en tres fases y tiers de presupuesto. Rediseño de logo con IA generativa y configuración de campañas en Facebook Business Manager.',
    tags: ['Meta Ads', 'WhatsApp API', 'AI Design'],
    url: '',
  },
];
---
<section id="projects">
  <p class="section-label">// Trabajo</p>
  <h2 class="section-title">Proyectos</h2>
  <div class="projects-grid">
    {projects.map(p => (
      <div class="project-card">
        <p class="project-type">{p.type}</p>
        <h3 class="project-title">{p.title}</h3>
        <p class="project-desc">{p.desc}</p>
        <div class="project-tags">
          {p.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
        {p.url && (
          <a href={p.url} target="_blank" rel="noopener" class="project-link">
            Ver proyecto →
          </a>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
    opacity: 0;
  }

  .project-card.visible {
    opacity: 1;
    transition: opacity 0.5s ease, border-color 0.2s, transform 0.2s;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }

  .project-card:hover::before { transform: scaleX(1); }

  .project-card:hover {
    border-color: rgba(255, 221, 0, 0.2);
    transform: translateY(-4px);
  }

  .project-type {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .project-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
  }

  .project-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 3px 8px;
    border: 1px solid rgba(255, 221, 0, 0.2);
  }

  .project-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    transition: letter-spacing 0.2s;
    align-self: flex-start;
  }

  .project-link:hover { letter-spacing: 0.05em; }
</style>

<script>
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.project-card').forEach(el => observer.observe(el));
</script>